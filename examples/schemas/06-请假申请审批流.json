[
  {
    "type": "ACTIVITY_SNAPSHOT",
    "content": {
      "components": [
        {
          "id": "root",
          "component": "form",
          "layout": "vertical",
          "spacing": 16,
          "padding": 16,
          "submitButtonId": "btn-submit",
          "children": [
            "page-title",
            "name-row",
            "reason-row",
            "leave-type-row",
            "time-range-group",
            "upload-row",
            "action-buttons"
          ]
        },
        {
          "id": "page-title",
          "component": "text",
          "content": "请假申请",
          "style": {
            "fontSize": "18px",
            "fontWeight": "bold"
          }
        },
        {
          "id": "name-row",
          "component": "box",
          "layout": "horizontal",
          "spacing": 10,
          "align": "center",
          "children": [
            "name-label",
            "name-value"
          ]
        },
        {
          "id": "name-label",
          "component": "text",
          "content": "姓名",
          "style": {
            "fontWeight": "bold",
            "width": "80px"
          }
        },
        {
          "id": "name-value",
          "component": "text",
          "content": "${$root.name}",
          "style": {
            "flex": 1
          }
        },
        {
          "id": "reason-row",
          "component": "box",
          "layout": "vertical",
          "spacing": 8,
          "children": [
            "reason-label",
            "reason-input"
          ]
        },
        {
          "id": "reason-label",
          "component": "text",
          "content": "申请事由",
          "style": {
            "fontWeight": "bold"
          }
        },
        {
          "id": "reason-input",
          "component": "textarea",
          "placeholder": "请输入申请事由",
          "value": {
            "path": "/reason"
          },
          "rules": [
            { "required": true, "message": "申请事由不能为空" }
          ]
        },
        {
          "id": "leave-type-row",
          "component": "box",
          "layout": "vertical",
          "spacing": 8,
          "children": [
            "leave-type-label",
            "leave-type-select"
          ]
        },
        {
          "id": "leave-type-label",
          "component": "text",
          "content": "休假类型",
          "style": {
            "fontWeight": "bold"
          }
        },
        {
          "id": "leave-type-select",
          "component": "select",
          "placeholder": "请选择休假类型",
          "value": {
            "path": "/leaveType"
          },
          "rules": [
            { "required": true, "message": "请选择休假类型" }
          ],
          "options": [
            { "label": "年休假", "value": "年休假" },
            { "label": "病假", "value": "病假" },
            { "label": "调休", "value": "调休" },
            { "label": "事假", "value": "事假" }
          ]
        },
        {
          "id": "time-range-group",
          "component": "box",
          "layout": "vertical",
          "spacing": 8,
          "children": [
            "time-range-label",
            "time-range-container"
          ]
        },
        {
          "id": "time-range-label",
          "component": "text",
          "content": "时间范围",
          "style": {
            "fontWeight": "bold"
          }
        },
        {
          "id": "time-range-container",
          "component": "box",
          "layout": "horizontal",
          "spacing": 8,
          "align": "center",
          "children": [
            "start-time-picker",
            "time-separator",
            "end-time-picker"
          ]
        },
        {
          "id": "start-time-picker",
          "component": "datepicker",
          "picker": "date",
          "showTime": true,
          "format": "YYYY-MM-DD HH:mm:ss",
          "placeholder": "开始时间",
          "value": {
            "path": "/startTime"
          },
          "rules": [
            { "required": true, "message": "请选择开始时间" }
          ],
          "style": {
            "flex": 1
          }
        },
        {
          "id": "time-separator",
          "component": "text",
          "content": "至"
        },
        {
          "id": "end-time-picker",
          "component": "datepicker",
          "picker": "date",
          "showTime": true,
          "format": "YYYY-MM-DD HH:mm:ss",
          "placeholder": "结束时间",
          "value": {
            "path": "/endTime"
          },
          "rules": [
            { "required": true, "message": "请选择结束时间" }
          ],
          "style": {
            "flex": 1
          }
        },
        {
          "id": "upload-row",
          "component": "box",
          "layout": "vertical",
          "spacing": 8,
          "children": [
            "upload-label",
            "upload-component"
          ]
        },
        {
          "id": "upload-label",
          "component": "text",
          "content": "上传凭证",
          "style": {
            "fontWeight": "bold"
          }
        },
        {
          "id": "upload-component",
          "component": "upload",
          "accept": "*/*",
          "showUploadList": true,
          "multiple": true,
          "maxCount": 10,
          "listType": "text",
          "value": {
            "path": "/proofFiles"
          }
        },
        {
          "id": "action-buttons",
          "component": "box",
          "layout": "horizontal",
          "justify": "center",
          "style": {
            "marginTop": "24px"
          },
          "children": [
            "btn-submit"
          ]
        },
        {
          "id": "btn-submit",
          "component": "button",
          "label": "确认提交",
          "type": "primary",
          "on_tap": [
            {
              "action": "http_proxy",
              "payload": {
                "http_config": {
                  "method": "POST",
                  "path": "https://www.baidu.com/api/leave/apply",
                  "headers": {
                    "Content-Type": "application/json"
                  }
                },
                "http_body": {
                  "name": { "path": "/name" },
                  "reason": { "path": "/reason" },
                  "leaveType": { "path": "/leaveType" },
                  "startTime": { "path": "/startTime" },
                  "endTime": { "path": "/endTime" },
                  "proofFiles": { "path": "/proofFiles" }
                }
              }
            },
            {
              "action": "message",
              "payload": {
                "type": "success",
                "content": "请假申请提交成功！"
              }
            }
          ]
        }
      ],
      "dataModel": {
        "name": "张三",
        "reason": "",
        "leaveType": "",
        "startTime": "",
        "endTime": "",
        "proofFiles": []
      }
    }
  }
]
