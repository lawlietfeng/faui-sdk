{
  "name": "@lawlietfeng/faui-sdk",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "description": "FAUI JSON Schema renderer SDK based on React and Ant Design",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./full": {
      "types": "./dist/full.d.ts",
      "import": "./dist/full.mjs",
      "require": "./dist/full.js"
    }
  },
  "sideEffects": [
    "./dist/chunk-*.js",
    "./dist/chunk-*.mjs",
    "./dist/index.*",
    "./dist/full.*"
  ],
  "scripts": {
    "dev": "vite --host 0.0.0.0 examples",
    "build": "tsup",
    "lint": "eslint src examples tests --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "@ant-design/icons": ">=5.0.0",
    "antd": ">=5.0.0",
    "dayjs": ">=1.10.0",
    "echarts": ">=5.0.0",
    "framer-motion": ">=10.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "echarts": {
      "optional": true
    },
    "framer-motion": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ant-design/icons": "^5.6.0",
    "@eslint/js": "^9.24.0",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.10",
    "antd": "^6.3.5",
    "autoprefixer": "^10.4.21",
    "dayjs": "^1.11.0",
    "echarts": "^6.0.0",
    "eslint": "^9.24.0",
    "framer-motion": "^12.38.0",
    "globals": "^16.0.0",
    "happy-dom": "^20.10.6",
    "postcss": "^8.5.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.2.2",
    "tsup": "^8.0.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vitest": "^4.1.9"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "json-schema",
    "renderer",
    "antd",
    "form",
    "sdk"
  ],
  "author": "lawliet",
  "repository": {
    "type": "git",
    "url": "https://github.com/lawlietfeng/faui-sdk.git"
  },
  "homepage": "https://github.com/lawlietfeng/faui-sdk#readme",
  "license": "MIT",
  "dependencies": {
    "fast-json-patch": "^3.1.1"
  }
}
