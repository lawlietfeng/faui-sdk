{
  "name": "@lawlietfeng/faui-sdk",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "description": "FAUI JSON Schema renderer SDK based on React and Ant Design",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "dev": "vite --host 0.0.0.0 examples",
    "build": "tsup",
    "lint": "eslint src examples --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "echo \"Test framework will be configured in a later iteration.\""
  },
  "peerDependencies": {
    "antd": ">=5.0.0",
    "dayjs": ">=1.10.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.24.0",
    "globals": "^16.0.0",
    "postcss": "^8.5.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.2.2",
    "tsup": "^8.0.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.4"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "json-schema",
    "renderer",
    "antd",
    "form",
    "sdk"
  ],
  "author": "lawliet",
  "repository": {
    "type": "git",
    "url": "https://github.com/lawlietfeng/faui-sdk.git"
  },
  "homepage": "https://github.com/lawlietfeng/faui-sdk#readme",
  "license": "AGPL-3.0-only"
}
